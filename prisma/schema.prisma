generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Position {
  id           String   @id @default(uuid())
  tokenAddress String
  type         String
  status       String
  entryPrice   Float
  size         Float
  exitPrice    Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tokenId      String?
  copiedFrom   String?
  source       String   @default("SCOUT")
  pnl          Float?
  tokenName    String?
  tokenSymbol  String?
  txHash       String?
  tradingMode  String   @default("LIVE")
  exitReason   String?
}

model Signal {
  id           String   @id @default(uuid())
  tokenAddress String
  score        Float
  passed       Boolean
  rawContext   Json
  createdAt    DateTime @default(now())
  copiedFrom   String?
  source       String   @default("SCOUT")
}

model Log {
  id        String   @id @default(uuid())
  level     String
  message   String
  meta      Json?
  createdAt DateTime @default(now())
}

model TrackedWallet {
  id                String    @id @default(uuid())
  address           String    @unique
  label             String?
  tier              Int       @default(2)
  bundleId          String?
  status            String    @default("ACTIVE")
  entrySource       String?
  totalSignals      Int       @default(0)
  copiedSignals     Int       @default(0)
  winRate           Float?
  avgPnlR           Float?
  lastTradeAt       DateTime?
  createdAt         DateTime  @default(now())
  consecutiveLosses Int       @default(0)
}

model SystemConfig {
  key   String @id
  value String
}

model WalletPosition {
  id             String   @id @default(uuid())
  walletAddress  String
  tokenAddress   String
  status         String   @default("OPEN")
  totalWethSpent Float
  totalTokens    Float
  avgEntryPrice  Float
  realizedPnl    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DexProtocol {
  id              String   @id @default(uuid())
  name            String
  version         String
  routerAddress   String?
  factoryAddress  String?
  quoterAddress   String?
  positionManager String?
  poolManager     String?
  stateView       String?
  verified        Boolean  @default(false)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
}

/// Tracks Uniswap V3 LP positions managed by LP Engine
model LPPosition {
  id              String   @id @default(uuid())
  tokenId         String   @unique
  txHash          String?
  pool            String
  token0          String
  token1          String
  token0Symbol    String?
  token1Symbol    String?
  feeTier         Int
  tickLower       Int
  tickUpper       Int
  entryValue      Float
  entryTick       Int      @default(0)
  simulatedLiquidity String? // For DRY_RUN simulated positions
  feesCollected   Float    @default(0)
  harvestedFees   Float    @default(0)
  ilRunning       Float    @default(0)
  feeAboveILHours Int      @default(0)
  ilAboveFeeHours Int      @default(0)
  mode            String   @default("MANUAL")
  status          String   @default("PENDING")
  dayMode         Boolean  @default(false)
  nightMode       Boolean  @default(false)
  sessionKeyId    String?
  tradingMode     String   @default("DRY_RUN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  source          String   @default("SYSTEM")
  managerAddress  String?
}

model SessionKey {
  id          String   @id @default(uuid())
  userId      String
  keyAddress  String   @unique
  scope       Json
  expiry      DateTime
  status      String   @default("ACTIVE")
  sdkProvider String   @default("alchemy")
  createdAt   DateTime @default(now())
}
