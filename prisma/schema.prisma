// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Position {
  id           String   @id @default(uuid())
  tokenAddress String
  type         String   // "TRENCH" or "LP"
  status       String   // "OPEN" or "CLOSED"
  entryPrice   Float
  size         Float
  exitPrice    Float?
  pnl          Float?   // PnL ratio ((exitPrice - entryPrice) / entryPrice)
  tokenId      String?  // Storage for Uniswap V3 LP NFT
  source       String   @default("SCOUT") // "SCOUT" or "COPYTRADE"
  copiedFrom   String?  // Wallet address if source is COPYTRADE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Signal {
  id           String   @id @default(uuid())
  tokenAddress String
  score        Float
  passed       Boolean
  rawContext   Json
  source       String   @default("SCOUT") // "SCOUT" or "COPYTRADE"
  copiedFrom   String?  // Wallet address if source is COPYTRADE
  createdAt    DateTime @default(now())
}

model Log {
  id        String   @id @default(uuid())
  level     String   // "INFO", "WARN", "ERROR"
  message   String
  meta      Json?
  createdAt DateTime @default(now())
}

model TrackedWallet {
  id            String   @id @default(uuid())
  address       String   @unique
  label         String?
  tier          Int      @default(2)
  bundleId      String?
  status        String   @default("ACTIVE") // ACTIVE, PAUSED, DEMOTED
  entrySource   String?
  totalSignals  Int      @default(0)
  copiedSignals Int      @default(0)
  winRate       Float?
  avgPnlR       Float?
  consecutiveLosses Int @default(0)
  lastTradeAt   DateTime?
  createdAt     DateTime @default(now())
}

model SystemConfig {
  key   String @id
  value String
}

model WalletPosition {
  id              String   @id @default(uuid())
  walletAddress   String
  tokenAddress    String
  status          String   @default("OPEN")
  totalWethSpent  Float    
  totalTokens     Float    
  avgEntryPrice   Float    
  realizedPnl     Float?   
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
